# 1. 경량화된 파이썬 3.12 베이스 이미지 사용 (용량 최적화)
FROM python:3.12-slim

# 2. 작업 디렉토리 설정
WORKDIR /app
ENV PYTHONPATH=/app

# 3. 패키기 설치 
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 4. 소스 코드 복사
COPY app/ /app/app/

# 5. 포트 노출
EXPOSE 8080

# 6. 실행 명령어 uvicorn으로 fastAPI 실행
CMD ["sh", "-c", "python -m uvicorn app.main:app --host 0.0.0.0 --port 8080"]
