{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI-Vehicle Manual Main",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/backend/.venv/bin/python3",
            "cwd": "${workspaceFolder}/backend",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--port",
                "8009"
            ],
            "console": "internalConsole",
            "env": {},
            "jinja": true,
            "justMyCode": true
        },
        {
            "name": "FastAPI-Vehicle Manual Inference Server",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/inference_server/.venv/bin/python3",
            "cwd": "${workspaceFolder}/inference_server",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--port",
                "8010"
            ],
            "console": "internalConsole",
            "env": {},
            "jinja": true,
            "justMyCode": true
        }
    ],
    "compounds": [
        {
            "name": "Vehicle Manual RAG Debug",
            "configurations": [
                "FastAPI-Vehicle Manual Main",
                "FastAPI-Vehicle Manual Inference Server"
            ]
        }
    ]
}